#!/bin/bash
# Reject commits from unrecognized identities.
# Add new committer emails to ALLOWED_EMAILS below.

ALLOWED_EMAILS=(
    "mefos-lab@proton.me"
    "noreply@anthropic.com"
)

AUTHOR_EMAIL=$(git config user.email)

for allowed in "${ALLOWED_EMAILS[@]}"; do
    if [ "$AUTHOR_EMAIL" = "$allowed" ]; then
        exit 0
    fi
done

echo "ERROR: Commit blocked — unrecognized email: $AUTHOR_EMAIL"
echo "Allowed emails:"
for allowed in "${ALLOWED_EMAILS[@]}"; do
    echo "  $allowed"
done
echo ""
echo "To fix: git config user.email <allowed-email>"
exit 1
